# ============================================
# VentureCanvas Combined .gitignore
# Covers: Python/Flask, Node/Vue/Quasar, IDE & OS
# ============================================

# ---------- Python / Flask ----------
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
*.egg
dist/
build/
*.whl
.Python
env/
venv/
.venv/
pip-log.txt
pip-delete-this-directory.txt
*.db
*.sqlite3
instance/
.pytest_cache/
htmlcov/
.coverage
.coverage.*
.tox/
.mypy_cache/
.ruff_cache/

# ---------- Node / Vue / Quasar ----------
node_modules/
dist/
.quasar/
.output/
*.tsbuildinfo
.npm
.eslintcache
.stylelintcache
*.tgz
.yarn-integrity
jspm_packages/
web_modules/

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# Vite
vite.config.js.timestamp-*
vite.config.ts.timestamp-*

# ---------- IDE & OS ----------
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
Desktop.ini

# ---------- Environment ----------
.env
.env.*
!.env.example

# ---------- Coverage ----------
coverage/
*.lcov
.nyc_output/
